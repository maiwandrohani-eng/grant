generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum GrantPriority {
  APPLY_NOW
  UPCOMING
  ROLLING
}

model Grant {
  id                         String        @id @default(cuid())
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt

  dedupeKey                  String        @unique
  sourceCategory             String
  sourceName                 String

  title                      String
  donor                      String?
  fundName                   String?
  url                        String
  snippet                    String?

  geographicFocus            String
  thematicFocus              String
  amountRange                String?

  deadline                   DateTime?
  deadlineType               String        // "FIXED" | "ROLLING" | "OPEN" | "UNKNOWN"

  eligibilitySummary         String?
  localRegistrationAdvantage Boolean       @default(false)

  relevanceScore             Int
  matchNote                  String
  priority                   GrantPriority

  rawJson                    Json?
}

model CronRun {
  id            String   @id @default(cuid())
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  ok            Boolean  @default(false)
  error         String?

  foundCount    Int      @default(0)
  keptCount     Int      @default(0)
  insertedCount Int      @default(0)
  emailedCount  Int      @default(0)
}

