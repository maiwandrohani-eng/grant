DATABASE_URL="postgresql://USER:PASSWORD@HOST/db?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/db?sslmode=require"

# Vercel Cron protection (vercel.json injects this header)
CRON_SECRET="change_me"

# Serper (Google-like search API)
SERPER_API_KEY="..."

# OpenAI for scoring/summarisation
OPENAI_API_KEY="..."
OPENAI_MODEL="gpt-4o-mini"

# Resend for email delivery
RESEND_API_KEY="..."
INARA_DIGEST_TO_EMAIL="grants@inara.org"
INARA_DIGEST_FROM_EMAIL="INARA Grants Bot <grants-bot@yourdomain.com>"

